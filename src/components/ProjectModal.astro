---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { data } = project;
const { Content } = await project.render();

const statusConfig = {
  completed: {
    bg: "bg-status-success-bg",
    text: "text-status-success-text",
    border: "border-status-success-border",
    label: "Completed",
  },
  "in-progress": {
    bg: "bg-status-info-bg",
    text: "text-status-info-text",
    border: "border-status-info-border",
    label: "In Progress",
  },
  planned: {
    bg: "bg-status-warning-bg",
    text: "text-status-warning-text",
    border: "border-status-warning-border",
    label: "Planned",
  },
  archived: {
    bg: "bg-status-neutral-bg",
    text: "text-status-neutral-text",
    border: "border-status-neutral-border",
    label: "Archived",
  },
};

const currentStatus = statusConfig[data.status] || statusConfig["in-progress"];

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", { month: "short", year: "numeric" });
---

<div
  id={`modal-${project.slug}`}
  class="modal-overlay fixed inset-0 z-50 overflow-y-auto"
  aria-modal="true"
  role="dialog"
  aria-labelledby={`modal-title-${project.slug}`}
>
  <!-- Backdrop (fixed so it doesn't scroll away) -->
  <div class="modal-backdrop fixed inset-0 bg-black/80"></div>

  <!-- Centering wrapper — pointer-events-none so backdrop clicks pass through to backdrop div -->
  <div class="pointer-events-none relative z-10 min-h-full flex items-start justify-center px-4 py-28">

  <!-- Panel -->
  <div class="modal-panel pointer-events-auto w-full max-w-3xl h-fit bg-bg-card border border-border-primary rounded-xl flex flex-col overflow-hidden shadow-2xl">
    <!-- Header -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-border-secondary">
      <div class="flex items-center gap-3 min-w-0">
        {
          data.favicon && (
            <img
              src={`/projects/favicons/${data.favicon}`}
              alt={`${data.title} favicon`}
              class="w-7 h-7 flex-shrink-0 rounded-sm"
              loading="lazy"
              onerror="this.style.display='none'"
            />
          )
        }
        <h2
          id={`modal-title-${project.slug}`}
          class="text-xl font-bold text-text-primary"
        >
          {data.title}
        </h2>
        <span
          class={`px-2 py-0.5 rounded text-sm font-medium border whitespace-nowrap flex-shrink-0 ${currentStatus.bg} ${currentStatus.text} ${currentStatus.border}`}
        >
          {currentStatus.label}
        </span>
      </div>
      <button
        class="modal-close ml-4 flex-shrink-0 p-1 text-text-secondary hover:text-text-primary transition-colors"
        aria-label="Close modal"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Body -->
    <div class="px-6 py-5 flex flex-col gap-5">
      <!-- Description -->
      <p class="text-text-secondary leading-relaxed">{data.description}</p>

      <!-- Technologies -->
      <div class="flex flex-wrap gap-2">
        {
          data.technologies.map((tech) => (
            <span class="px-2 py-1 bg-bg-overlay text-text-tertiary text-sm rounded-md border border-border-tertiary">
              {tech}
            </span>
          ))
        }
      </div>

      <!-- Timeline & Links -->
      <div class="flex flex-wrap gap-6 text-sm border-t border-border-secondary pt-4">
        <div>
          <span class="block text-text-secondary text-xs uppercase tracking-wide mb-1"
            >Timeline</span
          >
          <span class="text-text-primary">
            {formatDate(data.startDate)}
            {data.endDate ? ` — ${formatDate(data.endDate)}` : " — Present"}
          </span>
        </div>

        {
          (data.githubUrl || data.liveUrl) && (
            <div>
              <span class="block text-text-secondary text-xs uppercase tracking-wide mb-1">
                Links
              </span>
              <div class="flex items-center gap-4">
                {data.githubUrl && (
                  <a
                    href={data.githubUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-1.5 text-accent-primary hover:text-accent-hover transition-colors"
                  >
                    <svg
                      class="w-4 h-4"
                      fill="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                        clip-rule="evenodd"
                      />
                    </svg>
                    Source
                  </a>
                )}
                {data.liveUrl && (
                  <a
                    href={data.liveUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-1.5 text-accent-primary hover:text-accent-hover transition-colors"
                  >
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                      />
                    </svg>
                    Live
                  </a>
                )}
              </div>
            </div>
          )
        }
      </div>

      <!-- Achievements -->
      {
        data.achievements && data.achievements.length > 0 && (
          <div>
            <span class="block text-text-secondary text-xs uppercase tracking-wide mb-2">
              Achievements
            </span>
            <ul class="flex flex-col gap-1.5">
              {data.achievements.map((achievement) => (
                <li class="flex items-start gap-2 text-sm text-text-primary">
                  <span class="text-accent-primary mt-0.5 flex-shrink-0">
                    ✦
                  </span>
                  {achievement}
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <!-- Markdown Body -->
      <div class="prose prose-invert prose-sm max-w-none border-t border-border-secondary pt-4 pb-1">
        <Content />
      </div>
    </div>
  </div>
  </div>
</div>

<style>
  .modal-overlay {
    opacity: 0;
    pointer-events: none;
    transition: opacity 180ms ease;
  }

  .modal-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .modal-panel {
    opacity: 0;
    transform: translateY(12px) scale(0.97);
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  .modal-overlay.is-open .modal-panel {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
</style>

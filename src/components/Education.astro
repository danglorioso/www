    <!-- ── Tufts University ── -->
    <div class="flex gap-3 sm:gap-5 p-4 sm:p-6">
      <div class="flex-shrink-0 w-11 h-11 sm:w-12 sm:h-12 rounded-lg border border-border-secondary overflow-hidden">

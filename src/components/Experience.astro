<script>
  function formatDuration(startStr: string, endStr?: string): string {
    const [startYear, startMonth] = startStr.split('-').map(Number);
    const now = new Date();
    const end = endStr ? (() => { const [y, m] = endStr.split('-').map(Number); return new Date(y, m - 1); })() : new Date(now.getFullYear(), now.getMonth() + 1);

    let years = end.getFullYear() - startYear;
    let months = end.getMonth() + 1 - startMonth;
    if (months < 0) { years--; months += 12; }

    const parts: string[] = [];
    if (years > 0) parts.push(`${years} yr${years !== 1 ? 's' : ''}`);
    if (months > 0) parts.push(`${months} mo${months !== 1 ? 's' : ''}`);
    return parts.length ? parts.join(' ') : '< 1 mo';
  }

  document.querySelectorAll<HTMLElement>('span[data-start]').forEach(el => {
    el.textContent = formatDuration(el.dataset.start!, el.dataset.end);
  });
</script>

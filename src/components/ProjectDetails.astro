---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { data } = project;
const { Content } = await project.render();
---

<div class="project-details">
  <div class="inner">
    <div class="content">
      {
        data.achievements && data.achievements.length > 0 && (
          <div class="section">
            <span class="section-label">Achievements</span>
            <ul class="achievements-list">
              {data.achievements.map((achievement) => (
                <li class="achievement-item">
                  <span class="achievement-bullet">✦</span>
                  {achievement}
                </li>
              ))}
            </ul>
          </div>
        )
      }

      {
        data.collaborators && data.collaborators.length > 0 && (
          <div class="section">
            <span class="section-label">Collaborators</span>
            <div class="collaborators-list">
              {data.collaborators.map((name) => (
                <span class="collaborator-tag">{name}</span>
              ))}
            </div>
          </div>
        )
      }

      {
        project.body && project.body.trim().length > 0 && (
          <div class="prose-section">
            <div class="prose prose-invert prose-sm max-w-none">
              <Content />
            </div>
          </div>
        )
      }
      <div class="collapse-row">
        <button class="collapse-btn" data-collapse-btn aria-label="Collapse details">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="18 15 12 9 6 15"></polyline>
          </svg>
          Collapse
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .project-details {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 280ms ease;
  }

  .project-details.is-expanded {
    grid-template-rows: 1fr;
  }

  .inner {
    overflow: hidden;
  }

  .content {
    margin-top: -1px;
    border: 1px solid var(--border-primary);
    border-top: none;
    border-radius: 0 0 0.5rem 0.5rem;
    background: var(--bg-card);
    padding: 1.25rem 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
  }

  .achievements-list {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .achievement-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-primary);
  }

  .achievement-bullet {
    color: var(--accent-primary);
    flex-shrink: 0;
    margin-top: 0.1rem;
    font-size: 0.65rem;
  }

  .collaborators-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .collaborator-tag {
    padding: 0.25rem 0.625rem;
    background: var(--bg-overlay);
    color: var(--text-tertiary);
    font-size: 0.8125rem;
    border-radius: 9999px;
    border: 1px solid var(--border-tertiary);
  }

  .prose-section {
    border-top: 1px solid var(--border-secondary);
    padding-top: 1.25rem;
  }

  /* Only show top border if there's preceding content */
  .content > :first-child.prose-section {
    border-top: none;
    padding-top: 0;
  }

  .collapse-row {
    display: flex;
    justify-content: center;
    border-top: 1px solid var(--border-secondary);
    padding-top: 0.875rem;
  }

  .collapse-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-tertiary);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.625rem;
    border-radius: 0.25rem;
    transition: color 150ms ease, background 150ms ease;
  }

  .collapse-btn:hover {
    color: var(--text-secondary);
    background: var(--bg-overlay);
  }
</style>

<script>
  document.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest("[data-collapse-btn]");
    if (!btn) return;

    e.stopPropagation();

    const details = btn.closest(".project-details") as HTMLElement | null;
    const card = details?.previousElementSibling as HTMLElement | null;
    const chevron = card?.querySelector(".expand-chevron") as HTMLElement | null;

    details?.classList.remove("is-expanded");
    card?.classList.remove("is-expanded");
    if (chevron) chevron.style.transform = "";
  });
</script>
---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { data } = project;
const { Content } = await project.render();
---

<div class="project-details">
  <div class="inner">
    <div class="content">
      {
        data.achievements && data.achievements.length > 0 && (
          <div class="section">
            <span class="section-label">Achievements</span>
            <ul class="achievements-list">
              {data.achievements.map((achievement) => (
                <li class="achievement-item">
                  <span class="achievement-bullet">✦</span>
                  {achievement}
                </li>
              ))}
            </ul>
          </div>
        )
      }

      {
        data.collaborators && data.collaborators.length > 0 && (
          <div class="section">
            <span class="section-label">Collaborators</span>
            <div class="collaborators-list">
              {data.collaborators.map((name) => (
                <span class="collaborator-tag">{name}</span>
              ))}
            </div>
          </div>
        )
      }

      {
        project.body && project.body.trim().length > 0 && (
          <div class="prose-section">
            <div class="prose prose-invert prose-sm max-w-none">
              <Content />
            </div>
          </div>
        )
      }
    </div>
  </div>
</div>

<style>
  .project-details {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 280ms ease;
  }

  .project-details.is-expanded {
    grid-template-rows: 1fr;
  }

  .inner {
    overflow: hidden;
  }

  .content {
    margin-top: -1px;
    border: 1px solid var(--border-primary);
    border-top: none;
    border-radius: 0 0 0.5rem 0.5rem;
    background: var(--bg-card);
    padding: 1.25rem 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
  }

  .achievements-list {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .achievement-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-primary);
  }

  .achievement-bullet {
    color: var(--accent-primary);
    flex-shrink: 0;
    margin-top: 0.1rem;
    font-size: 0.65rem;
  }

  .collaborators-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .collaborator-tag {
    padding: 0.25rem 0.625rem;
    background: var(--bg-overlay);
    color: var(--text-tertiary);
    font-size: 0.8125rem;
    border-radius: 9999px;
    border: 1px solid var(--border-tertiary);
  }

  .prose-section {
    border-top: 1px solid var(--border-secondary);
    padding-top: 1.25rem;
  }

  /* Only show top border if there's preceding content */
  .content > :first-child.prose-section {
    border-top: none;
    padding-top: 0;
  }
</style>
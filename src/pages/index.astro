---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import AboutMe from "../components/AboutMe.astro";
import Experience from "../components/Experience.astro";
import Education from "../components/Education.astro";
import Interests from "../components/Interests.astro";
import Activity from "../components/Activity.astro";
import ContactForm from "../components/ContactForm.astro";
import ComingSoonBox from "../components/ComingSoonBox.astro";
---

<Layout
  title="Dan Glorioso | CS Student @ Tufts"
  description="Learn more about Dan Glorioso - CS Student @ Tufts, Full-Stack Developer, and passionate technologist"
  homepage={true}
>
  <section id="home">
    <div class="h-full w-full flex flex-col gap-12 md:gap-16">
      <!-- Hero Section -->
      <Hero />

      <!-- About Me Section -->
      <AboutMe />

      <!-- Activities Section -->
      <Activity />

      <!-- Experience Section -->
      <Experience />

      <!-- Education Section -->
      <Education />

      <!-- Interests & Hobbies Section -->
      <!-- <Interests /> -->

      <!-- Coming Soon Section -->
      <ComingSoonBox />

      <!-- Contact Form -->
      <div class="flex flex-col gap-6">
        <h2 class="text-3xl font-bold text-text-primary">Get In Touch</h2>
        <ContactForm />
      </div>
    </div>
  </section>
</Layout>

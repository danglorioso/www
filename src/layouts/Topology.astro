---
import "../globals.css";
import SpeedInsights from "@vercel/speed-insights/astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer";

interface Props {
  title: string;
  description?: string;
  homepage?: boolean;
}
const { title, description, homepage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="512x512" />
    <meta name="generator" content={Astro.generator} />
    <title>{homepage ? title : `${title} | Dan Glorioso`}</title>
  </head>

  <body class="min-h-screen flex flex-col">
    <canvas
      id="background-canvas"
      class="fixed top-0 left-0 w-full h-full pointer-events-none"
      style="background: var(--bg-primary, #0f172a);"></canvas>

    <div class="flex flex-col gap-4 flex-1">
      <!-- Header -->
      <Header />

      <!-- Header spacer to prevent content from being hidden behind fixed header -->
      <div class="h-20 sm:h-22"></div>

      <!-- Mobile Menu (slides from behind header) -->
      <div
        id="mobile-menu"
        class="md:hidden fixed left-0 right-0 z-40 transform -translate-y-full transition-all duration-300 ease-in-out pointer-events-none"
        aria-hidden="true"
      >
        <!-- Full Screen Backdrop -->
        <div
          class="fixed inset-0 bg-black/50 backdrop-blur-sm z-30"
          id="mobile-menu-backdrop"
        >
        </div>

        <!-- Menu Panel that slides from behind header -->
        <div
          class="relative z-40 bg-slate-900 border-b border-slate-700/50 shadow-2xl pt-20"
        >
          <!-- Navigation Links -->
          <nav class="px-6 py-6">
            <ul class="space-y-2" id="mobile-nav-links">
              <!-- Navigation items will be populated by JavaScript -->
            </ul>
          </nav>
        </div>
      </div>

      <!-- Page Content -->
      <main
        class="flex-1 flex flex-col max-w-5xl px-8 md:px-16 py-8 mx-auto w-full relative z-0 page-fade-in"
      >
        <slot />
      </main>

      <!-- Footer -->
      <Footer />
    </div>

    <!-- Back to Top Button -->
    <button
      id="back-to-top"
      class="fixed bottom-6 right-6 p-3 z-[100] bg-slate-850/90 hover:bg-slate-800/90 backdrop-blur-sm border border-slate-700/50 rounded-full shadow-lg transition-all duration-300 opacity-0 translate-y-2 pointer-events-none group"
      aria-label="Back to top"
    >
      <svg
        class="w-5 h-5 mx-auto text-gray-300 group-hover:text-white transition-colors duration-200"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
      </svg>
    </button>

    <!-- Vercel Speed Insights -->
    <SpeedInsights />

    <script is:inline>
      // Flowing Topology Lines Background
      class TopologyLines {
        constructor() {
          this.canvas = document.getElementById("background-canvas");
          this.ctx = this.canvas.getContext("2d");
          this.t = 0;

          // Config — tweak these to taste
          this.config = {
            lineCount: 14,        // number of contour lines
            opacity: 0.13,        // line opacity (0–1)
            lineWidth: 1.0,       // stroke width in px
            speed: 0.00018,       // how fast the field evolves
            noiseScale: 0.0018,   // zoom of the noise field (smaller = broader waves)
            segmentStep: 6,       // px between horizontal sample points
            scanlineStep: 55,     // px between vertical scanlines
          };

          this.bgColor = this.getBackgroundColor();
          this.lineColor = this.getLineColor();

          this.resize();
          this.bindEvents();
          this.animate();
        }

        getBackgroundColor() {
          const c = getComputedStyle(document.documentElement)
            .getPropertyValue("--bg-primary")
            .trim();
          return c || "#0f172a";
        }

        getLineColor() {
          const c = getComputedStyle(document.documentElement)
            .getPropertyValue("--text-secondary")
            .trim();
          return c || "#94a3b8";
        }

        colorToRgb(color) {
          if (!color) return [148, 163, 184];
          if (color.startsWith("#")) {
            let hex = color.replace(/^#/, "");
            if (hex.length === 3) hex = hex.split("").map(h => h + h).join("");
            const n = parseInt(hex, 16);
            return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
          }
          if (color.startsWith("rgb")) {
            const m = color.match(/\d+/g);
            return [parseInt(m[0]), parseInt(m[1]), parseInt(m[2])];
          }
          // oklch or other — fallback
          return [148, 163, 184];
        }

        resize() {
          this.canvas.width = window.innerWidth;
          this.canvas.height = window.innerHeight;
        }

        bindEvents() {
          window.addEventListener("resize", () => this.resize());
        }

        // Layered sine-wave noise — smooth, no external lib needed.
        // Returns a value roughly in [-1, 1].
        noise(x, y, t) {
          return (
            Math.sin(x * 1.3 + t * 1.7 + Math.cos(y * 0.9 + t)) * 0.40 +
            Math.sin(y * 1.1 - t * 1.3 + Math.sin(x * 0.7 - t * 0.8)) * 0.30 +
            Math.sin((x + y) * 0.8 + t * 2.1) * 0.20 +
            Math.cos(x * 0.5 - y * 1.4 + t * 0.9) * 0.10
          );
        }

        field(x, y, t) {
          return this.noise(x * this.config.noiseScale, y * this.config.noiseScale, t);
        }

        // Draw one contour line at the given threshold value
        drawContourLine(threshold, t, r, g, b) {
          const { segmentStep, scanlineStep, opacity, lineWidth } = this.config;
          const W = this.canvas.width;
          const H = this.canvas.height;
          const ctx = this.ctx;

          ctx.strokeStyle = `rgba(${r}, ${g}, ${b}, ${opacity})`;
          ctx.lineWidth = lineWidth;
          ctx.lineJoin = "round";
          ctx.lineCap = "round";

          // For each horizontal scanband, trace where field crosses threshold
          for (let bandY = -scanlineStep; bandY < H + scanlineStep; bandY += scanlineStep) {
            ctx.beginPath();
            let drawing = false;

            for (let x = -segmentStep; x <= W + segmentStep; x += segmentStep) {
              const fTop = this.field(x, bandY, t) - threshold;
              const fBot = this.field(x, bandY + scanlineStep, t) - threshold;

              if (fTop * fBot < 0) {
                // Binary-search the crossing y within this band
                let lo = bandY;
                let hi = bandY + scanlineStep;
                const fLo0 = this.field(x, lo, t) - threshold;
                for (let i = 0; i < 8; i++) {
                  const mid = (lo + hi) / 2;
                  const fMid = this.field(x, mid, t) - threshold;
                  if (fLo0 * fMid <= 0) hi = mid;
                  else lo = mid;
                }
                const crossY = (lo + hi) / 2;

                if (!drawing) {
                  ctx.moveTo(x, crossY);
                  drawing = true;
                } else {
                  ctx.lineTo(x, crossY);
                }
              } else {
                if (drawing) {
                  ctx.stroke();
                  ctx.beginPath();
                  drawing = false;
                }
              }
            }

            if (drawing) ctx.stroke();
          }
        }

        animate() {
          const { lineCount, speed } = this.config;
          const [r, g, b] = this.colorToRgb(this.lineColor);

          // Clear with bg color
          this.ctx.fillStyle = this.bgColor;
          this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

          // Spread thresholds evenly across [-1, 1]
          for (let i = 0; i < lineCount; i++) {
            const threshold = -1 + (2 / (lineCount - 1)) * i;
            this.drawContourLine(threshold, this.t, r, g, b);
          }

          this.t += speed * 60;
          requestAnimationFrame(() => this.animate());
        }
      }

      // Back to Top Button Functionality
      function initBackToTop() {
        const backToTopBtn = document.getElementById("back-to-top");
        if (!backToTopBtn) return;

        function toggleButtonVisibility() {
          const scrollTop =
            window.pageYOffset || document.documentElement.scrollTop;

          if (scrollTop > 300) {
            backToTopBtn.classList.remove(
              "opacity-0",
              "translate-y-2",
              "pointer-events-none"
            );
            backToTopBtn.classList.add("opacity-100", "translate-y-0");
          } else {
            backToTopBtn.classList.add(
              "opacity-0",
              "translate-y-2",
              "pointer-events-none"
            );
            backToTopBtn.classList.remove("opacity-100", "translate-y-0");
          }
        }

        function scrollToTop() {
          window.scrollTo({ top: 0, behavior: "smooth" });
        }

        window.addEventListener("scroll", toggleButtonVisibility);
        backToTopBtn.addEventListener("click", scrollToTop);
        toggleButtonVisibility();
      }

      // Initialize when DOM is loaded
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", () => {
          new TopologyLines();
          initBackToTop();
        });
      } else {
        new TopologyLines();
        initBackToTop();
      }
    </script>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html,
  body {
    font-family:
      -apple-system, BlinkMacSystemFont, Inter, system-ui, sans-serif;
    overflow-x: hidden;
  }

  body {
    background: var(--bg-primary);
    min-height: 100vh;
  }

  /* Text selection highlight color */
  ::selection {
    background-color: var(--accent-primary);
    color: var(--text-primary);
  }

  ::-moz-selection {
    background-color: var(--accent-primary);
    color: var(--text-primary);
  }
</style>
---
import "../globals.css";
import SpeedInsights from "@vercel/speed-insights/astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer";

interface Props {
  title: string;
  description?: string;
  homepage?: boolean;
}
const { title, description, homepage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="512x512" />
    <meta name="generator" content={Astro.generator} />
    <title>{homepage ? title : `${title} | Dan Glorioso`}</title>
  </head>

  <body class="min-h-screen flex flex-col">
    <canvas
      id="background-canvas"
      class="fixed top-0 left-0 w-full h-full pointer-events-none"
      style="background: var(--bg-primary, #0f172a);"></canvas>

    <div class="flex flex-col gap-4 flex-1">
      <!-- Header -->
      <Header />

      <!-- Header spacer to prevent content from being hidden behind fixed header -->
      <div class="h-20 sm:h-22"></div>

      <!-- Mobile Menu (slides from behind header) -->
      <div
        id="mobile-menu"
        class="md:hidden fixed left-0 right-0 z-40 transform -translate-y-full transition-all duration-300 ease-in-out pointer-events-none"
        aria-hidden="true"
      >
        <!-- Full Screen Backdrop -->
        <div
          class="fixed inset-0 bg-black/50 backdrop-blur-sm z-30"
          id="mobile-menu-backdrop"
        >
        </div>

        <!-- Menu Panel that slides from behind header -->
        <div
          class="relative z-40 bg-slate-900 border-b border-slate-700/50 shadow-2xl pt-20"
        >
          <!-- Navigation Links -->
          <nav class="px-6 py-6">
            <ul class="space-y-2" id="mobile-nav-links">
              <!-- Navigation items will be populated by JavaScript -->
            </ul>
          </nav>
        </div>
      </div>

      <!-- Page Content -->
      <main
        class="flex-1 flex flex-col max-w-5xl px-8 md:px-16 py-8 mx-auto w-full relative z-0 page-fade-in"
      >
        <slot />
      </main>

      <!-- Footer -->
      <Footer />
    </div>

    <!-- Back to Top Button -->
    <button
      id="back-to-top"
      class="fixed bottom-6 right-6 p-3 z-[100] bg-slate-850/90 hover:bg-slate-800/90 backdrop-blur-sm border border-slate-700/50 rounded-full shadow-lg transition-all duration-300 opacity-0 translate-y-2 pointer-events-none group"
      aria-label="Back to top"
    >
      <svg
        class="w-5 h-5 mx-auto text-gray-300 group-hover:text-white transition-colors duration-200"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
      </svg>
    </button>

    <!-- Vercel Speed Insights -->
    <SpeedInsights />

    <script is:inline>
      // Floating Dots Grid Background
      class FloatingDotsGrid {
        constructor() {
          this.canvas = document.getElementById("background-canvas");
          this.ctx = this.canvas.getContext("2d");
          this.dots = [];
          this.t = 0;

          // Config — tweak these to taste
          this.config = {
            spacing: 38,      // px between grid points
            dotRadius: 1.4,   // dot size in px
            opacity: 0.18,    // dot opacity (0–1)
            driftSpeed: 0.3,  // animation speed multiplier (0 = static)
            driftAmp: 2.5,    // max drift distance in px
          };

          this.bgColor = this.getBackgroundColor();
          this.dotColor = this.getDotColor();

          this.resize();
          this.buildGrid();
          this.bindEvents();
          this.animate();
        }

        getBackgroundColor() {
          const c = getComputedStyle(document.documentElement)
            .getPropertyValue("--bg-primary")
            .trim();
          return c || "#0f172a";
        }

        getDotColor() {
          // Use a soft light-slate color that reads on dark bg;
          // tweak or swap to --accent-primary if you prefer colored dots
          const c = getComputedStyle(document.documentElement)
            .getPropertyValue("--text-secondary")
            .trim();
          return c || "#94a3b8"; // slate-400 fallback
        }

        hexToRgb(hex) {
          // Handles 3- and 6-char hex
          hex = hex.replace(/^#/, "");
          if (hex.length === 3) hex = hex.split("").map(h => h + h).join("");
          const n = parseInt(hex, 16);
          return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
        }

        colorToRgb(color) {
          if (!color) return [148, 163, 184];
          if (color.startsWith("#")) return this.hexToRgb(color);
          if (color.startsWith("rgb")) {
            const m = color.match(/\d+/g);
            return [parseInt(m[0]), parseInt(m[1]), parseInt(m[2])];
          }
          // oklch or other — fall back to slate-400
          return [148, 163, 184];
        }

        resize() {
          this.canvas.width = window.innerWidth;
          this.canvas.height = window.innerHeight;
        }

        buildGrid() {
          this.dots = [];
          const { spacing, driftAmp } = this.config;
          const cols = Math.ceil(this.canvas.width / spacing) + 2;
          const rows = Math.ceil(this.canvas.height / spacing) + 2;

          for (let c = 0; c < cols; c++) {
            for (let r = 0; r < rows; r++) {
              this.dots.push({
                baseX: c * spacing,
                baseY: r * spacing,
                phaseX: Math.random() * Math.PI * 2,
                phaseY: Math.random() * Math.PI * 2,
                amp: driftAmp * (0.6 + Math.random() * 0.8),
              });
            }
          }
        }

        bindEvents() {
          window.addEventListener("resize", () => {
            this.resize();
            this.buildGrid();
          });
        }

        animate() {
          const { dotRadius, opacity, driftSpeed } = this.config;
          const [r, g, b] = this.colorToRgb(this.dotColor);

          // Clear with bg color
          this.ctx.fillStyle = this.bgColor;
          this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

          // Draw dots
          this.ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${opacity})`;
          for (const d of this.dots) {
            const x = d.baseX + Math.sin(this.t * driftSpeed + d.phaseX) * d.amp;
            const y = d.baseY + Math.cos(this.t * driftSpeed + d.phaseY) * d.amp;
            this.ctx.beginPath();
            this.ctx.arc(x, y, dotRadius, 0, Math.PI * 2);
            this.ctx.fill();
          }

          this.t += 0.01;
          requestAnimationFrame(() => this.animate());
        }
      }

      // Back to Top Button Functionality
      function initBackToTop() {
        const backToTopBtn = document.getElementById("back-to-top");
        if (!backToTopBtn) return;

        function toggleButtonVisibility() {
          const scrollTop =
            window.pageYOffset || document.documentElement.scrollTop;

          if (scrollTop > 300) {
            backToTopBtn.classList.remove(
              "opacity-0",
              "translate-y-2",
              "pointer-events-none"
            );
            backToTopBtn.classList.add("opacity-100", "translate-y-0");
          } else {
            backToTopBtn.classList.add(
              "opacity-0",
              "translate-y-2",
              "pointer-events-none"
            );
            backToTopBtn.classList.remove("opacity-100", "translate-y-0");
          }
        }

        function scrollToTop() {
          window.scrollTo({
            top: 0,
            behavior: "smooth",
          });
        }

        window.addEventListener("scroll", toggleButtonVisibility);
        backToTopBtn.addEventListener("click", scrollToTop);
        toggleButtonVisibility();
      }

      // Initialize when DOM is loaded
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", () => {
          new FloatingDotsGrid();
          initBackToTop();
        });
      } else {
        new FloatingDotsGrid();
        initBackToTop();
      }
    </script>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html,
  body {
    font-family:
      -apple-system, BlinkMacSystemFont, Inter, system-ui, sans-serif;
    overflow-x: hidden;
  }

  body {
    background: var(--bg-primary);
    min-height: 100vh;
  }

  /* Text selection highlight color */
  ::selection {
    background-color: var(--accent-primary);
    color: var(--text-primary);
  }

  ::-moz-selection {
    background-color: var(--accent-primary);
    color: var(--text-primary);
  }
</style>